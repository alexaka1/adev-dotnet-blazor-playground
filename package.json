{
  "name": "blazorplayground",
  "private": true,
  "scripts": {
    "tailwind:build": "tailwindcss -i ./src/Web/Styles/app.css -o ./src/Web/wwwroot/styles/app.css",
    "tailwind:build:minify": "tailwindcss -i ./src/Web/Styles/app.css -o ./src/Web/wwwroot/styles/app.css --minify",
    "tailwind:watch": "tailwindcss -i ./src/Web/Styles/app.css -o ./src/Web/wwwroot/styles/app.css --watch",
    "fmt": "rustywind --output-css-file ./src/Web/wwwroot/styles/app.css --check-formatted ./src",
    "fmt:fix": "rustywind --output-css-file ./src/Web/wwwroot/styles/app.css --write ./src"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "rustywind": "^0.23.1",
    "tailwindcss": "^3.4.17"
  },
  "packageManager": "pnpm@9.15.5+sha512.845196026aab1cc3f098a0474b64dfbab2afe7a1b4e91dd86895d8e4aa32a7a6d03049e2d0ad770bbe4de023a7122fb68c1a1d6e0d033c7076085f9d5d4800d4"
}
